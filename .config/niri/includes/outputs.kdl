// ──  Outputs ──────────────────────────

output "eDP-1" {
    mode "1920x1080@60"
    scale 1.1
    transform "normal"
    position x=0 y=0
}

output "DP-1" {
    mode "2560x1440@180.0"
    scale 1.0
    position x=1080 y=0
    focus-at-startup
}

output "HDMI-A-1" {
    mode "1920x1080@60"
    scale 1.0
    transform "270"
    position x=0 y=0
}

output "HDMI-A-2" {
    off
}
